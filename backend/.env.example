# ============================================================
# Modèle de configuration backend WebAR.
# Copie ce fichier en .env puis remplace les valeurs par les tiennes.
# .env n'est JAMAIS versionné (voir .gitignore). Ce .env.example, oui.
# ============================================================

# --- Connexion MySQL (SQLAlchemy + driver PyMySQL) ---
# Format : mysql+pymysql://UTILISATEUR:MOT_DE_PASSE@HOTE:PORT/NOM_DE_LA_BASE
# Exemple local typique avec l'utilisateur root :
#   mysql+pymysql://root:tonMotDePasse@localhost:3306/webar
DATABASE_URL=mysql+pymysql://webar_user:MonMotDePasse123@localhost:3306/webar

# --- TLS MySQL (hébergeur managé type Aiven) ---
# Chemin du certificat CA pour chiffrer la connexion. VIDE en local.
# En prod (Aiven) : télécharge le CA depuis la console et indique son chemin.
DATABASE_SSL_CA=

# --- CORS : origines autorisées (frontend React), séparées par des virgules ---
# En prod : mettre l'URL publique HTTPS du frontend Vercel (ex. https://webar.vercel.app)
CORS_ORIGINS=http://localhost:5173

# --- URL de base du frontend (encodée dans le QR code) ---
# En prod, mettre l'URL publique HTTPS du frontend.
FRONTEND_BASE_URL=http://localhost:5173

# --- Dev : afficher les requêtes SQL dans la console (true / false) ---
SQL_ECHO=false

# --- Authentification backoffice (JWT) ---
# Clé secrète de signature des jetons. GÉNÈRE LA TIENNE, ne réutilise jamais cet exemple :
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=remplace-moi-par-une-cle-aleatoire-longue-et-secrete
# Algorithme de signature et durée de validité du jeton (en minutes).
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=60
