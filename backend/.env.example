# ============================================================
# Modèle de configuration backend WebAR.
# Copie ce fichier en .env puis remplace les valeurs par les tiennes.
# .env n'est JAMAIS versionné (voir .gitignore). Ce .env.example, oui.
# ============================================================

# --- Connexion MySQL (SQLAlchemy + driver PyMySQL) ---
# Format : mysql+pymysql://UTILISATEUR:MOT_DE_PASSE@HOTE:PORT/NOM_DE_LA_BASE
# Exemple local typique avec l'utilisateur root :
#   mysql+pymysql://root:tonMotDePasse@localhost:3306/webar
DATABASE_URL=mysql+pymysql://webar_user:MonMotDePasse123@localhost:3306/webar

# --- CORS : origines autorisées (frontend React), séparées par des virgules ---
CORS_ORIGINS=http://localhost:5173

# --- URL de base du frontend (encodée dans le QR code) ---
# En prod, mettre l'URL publique HTTPS du frontend.
FRONTEND_BASE_URL=http://localhost:5173

# --- Dev : afficher les requêtes SQL dans la console (true / false) ---
SQL_ECHO=false
