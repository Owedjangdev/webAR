# Ignorer tous les fichiers et dossiers par défaut
/*

# Garder ce fichier
!/.gitignore

# Autoriser le dossier des règles et son contenu
!/rules/
!/rules/**

# Autoriser le dossier des skills et son contenu
!/skills/
!/skills/**

# Ignorer explicitement les caches et données générés
/agents/
/backups/
/cache/
/debug/
/downloads/
/file-history/
/ide/
/paste-cache/
/plans/
/plugins/
/projects/
/session-env/
/sessions/
/shell-snapshots/
/tasks/
.last-cleanup
.last-update-result.json
history.jsonl
mcp-needs-auth-cache*
*.local.json
