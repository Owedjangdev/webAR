# ============================================================
# .gitignore — Monorepo WebAR (frontend React + backend FastAPI)
# À placer à la racine du dépôt, avant le premier commit.
# ============================================================

# ----- Secrets & environnement (NE JAMAIS POUSSER) -----
.env
.env.*
!.env.example
*.local

# ============================================================
# FRONTEND — Node / React / Vite
# ============================================================
frontend/node_modules/
node_modules/
frontend/dist/
dist/
frontend/.vite/
.vite/

# Logs npm / yarn / pnpm
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Cache build
.cache/
*.tsbuildinfo

# ============================================================
# BACKEND — Python / FastAPI
# ============================================================
backend/__pycache__/
__pycache__/
*.py[cod]
*$py.class

# Environnements virtuels
backend/.venv/
backend/venv/
.venv/
venv/
env/

# Outils Python
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
.coverage
htmlcov/

# ----- Base de données locale (dumps versionnés à part) -----
*.sqlite3
*.db

# Fichiers uploadés en local par les utilisateurs (assets dynamiques)
# Garde le dossier mais ignore son contenu généré :
backend/static/uploads/*
!backend/static/uploads/.gitkeep

# ============================================================
# ÉDITEUR & SYSTÈME
# ============================================================
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
.DS_Store
Thumbs.db
*.swp